{
  // OpenCode 配置文件 Schema
  "$schema": "https://opencode.ai/config.json",

  // 默认使用的 AI 模型
  "model": "anthropic/claude-sonnet-4-5",

  // 自动更新设置
  "autoupdate": true,

  // 服务器配置
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },

  // TUI 界面配置
  "tui": {
    "scroll_speed": 3,
    "scroll_acceleration": {
      "enabled": true
    },
    "diff_style": "auto"
  },

  // 权限控制配置
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "./secrets/**": "deny"
    },
    "edit": {
      "*": "ask",
      "src/**": "allow"
    },
    "bash": {
      "*": "ask",
      "git *": "allow",
      "rm *": "deny"
    }
  },

  // 工具启用配置
  "tools": {
    "write": true,
    "bash": true,
    "webfetch": true
  },

  // 项目说明
  "instructions": {
    "default": "Android 逆向工程工具项目，包含 jadx-gui、apktool 及其 MCP 服务器。"
  },

  // 文件监控忽略配置
  "watcher": {
    "ignore": [
      "node_modules/**",
      "*.log",
      ".git/**",
      "java/jre/**",
      "*.zip",
      "*.jar"
    ]
  },

  // MCP 服务器配置
  "mcp": {
    // jadx MCP 服务器 (Java JAR 版本)
    "jadx-mcp-server": {
      "type": "stdio",
      "command": "java",
      "args": [
        "-jar",
        "E:/A_java/java/jadx-mcp-server/jadx-ai-mcp-6.3.0.jar"
      ],
      "enabled": true
    },

    // jadx MCP 服务器 (Python 版本)
    "jadx-mcp-python": {
      "type": "stdio",
      "command": "python",
      "args": [
        "E:/A_java/java/jadx-mcp-server/jadx-mcp-server/jadx_mcp_server.py"
      ],
      "enabled": false
    },

    // apktool MCP 服务器
    "apktool-mcp-server": {
      "type": "stdio",
      "command": "python",
      "args": [
        "E:/A_java/java/apktool-mcp-server/apktool-mcp-server/apktool_mcp_server.py",
        "--workspace",
        "E:/A_java/apktool_workspace",
        "--apktool-path",
        "E:/A_java/java/apktool/apktool.bat"
      ],
      "enabled": true
    }
  }
}
